generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// One weekly review cycle. A plan is created (as "draft") from whatever
// the forecast currently recommends, then someone works through it --
// approving or overriding each product -- and locks it once done. Locking
// doesn't stop new plans from being created for later weeks; it just
// freezes this one as the historical record of what was actually decided.
model ForecastPlan {
  id        String     @id @default(cuid())
  weekStart String // ISO date, the Monday this plan is for
  status    String     @default("draft") // "draft" | "locked"
  createdAt DateTime   @default(now())
  lockedAt  DateTime?
  lockedBy  String?
  items     PlanItem[]

  @@unique([weekStart])
}

// One product's line within a plan. Keeps the recommended number AND the
// approved number as two separate fields on purpose -- that's the
// before/after the review asked for, not an overwrite.
model PlanItem {
  id             String            @id @default(cuid())
  plan           ForecastPlan      @relation(fields: [planId], references: [id], onDelete: Cascade)
  planId         String
  productName    String
  category       String
  channel        String            @default("Market") // "Market" | "Online" -- snapshotted from the forecast; lets the same product have a separate line per channel
  marketName     String? // which physical market this line belongs to, snapshotted from the forecast -- null for Online lines
  recommendedQty Int
  recommendedKg  Float?
  approvedQty    Int?
  approvedKg     Float?
  decision       String            @default("pending") // "pending" | "approved" | "overridden"
  alertStatus    String // "ok" | "declining" | "high_growth" | "low_data" -- snapshotted from the forecast when the plan was created
  alertReason    String?
  reviewedBy     String?
  reviewedAt     DateTime?
  history        PlanItemHistory[]

  @@unique([planId, productName, channel])
  @@index([productName])
}

// Every single action taken on a plan item, ever. This is the audit trail
// -- nothing here is ever deleted or overwritten, only appended to.
model PlanItemHistory {
  id          String   @id @default(cuid())
  planItem    PlanItem @relation(fields: [planItemId], references: [id], onDelete: Cascade)
  planItemId  String
  action      String // "approved" | "overridden" | "edited" | "reopened"
  previousQty Int?
  newQty      Int?
  actor       String? // free-text name -- there's no login system, so whoever's reviewing types their name
  note        String?
  createdAt   DateTime @default(now())

  @@index([planItemId])
}

// Real weekly sales data -- one row per product per ISO week, with actual
// weight in kg already provided. This is a genuinely better data source
// than MonthlySales: real week-over-week granularity means the forecast
// no longer needs to guess/estimate a weekly figure from a monthly total.
model WeeklySales {
  id          String   @id @default(cuid())
  weekStart   String // ISO date, the Monday of that week
  weekLabel   String // e.g. "Week 11, 2026" -- for display
  plu         String // the PLU code, e.g. "21" -- closest thing to a SKU in this source
  productName String
  channel     String   @default("Market") // "Market" (in-store/default) | "Online" -- only set to Online when the source file explicitly says so
  marketName  String? // which physical market stall this was sold through -- only set when channel is "Market". Dummy-assigned for now (deterministic per PLU) until a real source column exists.
  weightKg    Float
  units       Int
  revenue     Float?
  importedAt  DateTime @default(now())

  @@unique([weekStart, plu, channel])
  @@index([productName])
}

// One row per product per month, straight from a monthly sales report
// (e.g. a "quarter sales" export with one sheet per month). Coarser than
// OrderItem -- no per-order date, no weight -- but this is the shape the
// real data currently comes in, so the forecast has to work with it.
model MonthlySales {
  id          String   @id @default(cuid())
  month       String // "YYYY-MM"
  monthLabel  String // "April 2026" -- for display
  isPartial   Boolean  @default(false) // true if the source range doesn't cover the full month (i.e. this is the current month "to date")
  productName String
  sku         String?
  itemsSold   Int
  revenue     Float?
  orders      Int?
  variations  Int?
  importedAt  DateTime @default(now())

  @@unique([month, productName])
  @@index([productName])
}

// One row per source order (header-level)
model Order {
  id         String      @id @default(cuid())
  externalId String      @unique // Order ID / Order Number from the source system
  orderDate  DateTime
  status     String?
  channel    String? // e.g. "Direct", "Shopify", "WooCommerce"
  items      OrderItem[]
  createdAt  DateTime    @default(now())

  @@index([orderDate])
}

// One row per product line inside an order
model OrderItem {
  id          String   @id @default(cuid())
  order       Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  orderId     String
  productName String
  sku         String?
  category    String?
  quantity    Float
  weightG     Float?
  itemCost    Float?

  @@index([productName])
  @@index([sku])
}

// Drives which columns render on the forecast table, in what order, and how
// they're formatted -- editable via the /api/columns endpoint without a code change.
model DashboardColumn {
  id        String   @id @default(cuid())
  key       String   @unique // must match a field name returned by the forecast calculator
  label     String
  type      String // "text" | "number" | "kg" | "percent" | "badge"
  sortOrder Int
  visible   Boolean  @default(true)
  updatedAt DateTime @updatedAt
}

// Audit trail of every data import, whatever the source
model ImportLog {
  id         String   @id @default(cuid())
  sourceType String // "csv_file" | "csv_url" | "google_sheets"
  sourceRef  String? // file path or URL, for traceability
  rowCount   Int
  status     String // "success" | "partial" | "failed"
  message    String?
  importedAt DateTime @default(now())
}
