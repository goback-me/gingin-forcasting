# Postgres connection -- matches docker-compose.yml if you use it as-is
# If you changed the host port in docker-compose.yml (e.g. because 5433 was
# already taken by something else), update the port here to match.
DATABASE_URL="postgresql://gingin:gingin@localhost:5435/gingin_forecast"

# Where order data comes from. Nothing else in the app needs to change when
# you swap this -- the importer maps whatever column headers the source uses.
#
# Local file (today):
SOURCE_REF="./data/orders-with-dates.xlsx"
#
# Google Sheets (later): in the sheet, File > Share > Publish to web > CSV,
# then paste the link it gives you here. Same importer, same code.
# SOURCE_REF="https://docs.google.com/spreadsheets/d/e/XXXXXXX/pub?output=csv"

# The monthly sales report (one sheet per month) -- this is what the
# dashboard actually runs off right now.
MONTHLY_SOURCE_REF="./data/quarter-sales.xls"
